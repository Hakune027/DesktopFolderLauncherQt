	$(MAKE) $(MAKESILENT) -f CMakeFiles\DesktopFolderLauncher.dir\build.make CMakeFiles/DesktopFolderLauncher.dir/main.cpp.i
.PHONY : main.cpp.i

main.s: main.cpp.s
.PHONY : main.s

# target to generate assembly for a file
main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\DesktopFolderLauncher.dir\build.make CMakeFiles/DesktopFolderLauncher.dir/main.cpp.s
.PHONY : main.cpp.s

